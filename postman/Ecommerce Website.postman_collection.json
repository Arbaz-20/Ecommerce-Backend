{
  "info": {
    "name": "Ecommerce Backend",
    "_postman_id": "a6c2f4d2-3b9d-4cc1-9b1c-ecom-backend-001",
    "description": "Complete REST API collection for the Ecommerce Backend (Node.js + TypeScript + Express + Sequelize/PostgreSQL).\n\n## Setup\n1. Import this file into Postman: **File → Import**.\n2. Open the **Variables** tab on the collection and confirm:\n   - `API` = `http://localhost:5000/api` (change host/port to match your `.env` `PORT`).\n   - `token` = leave empty; it auto-fills after a successful `Auth / Login`.\n3. Start the server: `npm start`.\n4. Hit **Auth → Create User** to register, then **Auth → Login** — the test script saves the JWT to `{{token}}` and every protected request uses it as `Authorization: Bearer {{token}}`.\n\n## Folder Map\n- **Auth** — register, login, logout, user CRUD\n- **Role** — role CRUD\n- **Category** — category CRUD\n- **Product** — product CRUD (multipart image upload)\n- **Cart** — cart CRUD + lookup by user\n- **Favourite** — favourite CRUD + lookup by user\n- **Order** — order CRUD + status / payment status updates\n\nAll URLs use `{{API}}` as the route prefix (e.g. `{{API}}/auth/loginController`).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "API",
      "value": "http://localhost:5000/api",
      "type": "string",
      "description": "Base URL prefix for every endpoint. Change to match your server host/port."
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT auto-saved by the Login request's test script."
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "description": "User registration, login/logout and user management.",
      "item": [
        {
          "name": "Create User (Register)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "John Doe", "type": "text" },
                { "key": "email", "value": "john@example.com", "type": "text" },
                { "key": "password", "value": "Password@123", "type": "text" },
                { "key": "address", "value": "221B Baker Street", "type": "text" },
                { "key": "age", "value": "28", "type": "text" },
                { "key": "country", "value": "Pakistan", "type": "text" },
                { "key": "city", "value": "Karachi", "type": "text" },
                { "key": "roleId", "value": "", "type": "text", "description": "Optional UUID of an existing role" },
                { "key": "image", "type": "file", "src": [], "description": "Profile picture (optional)" }
              ]
            },
            "url": { "raw": "{{API}}/auth/createUser", "host": ["{{API}}"], "path": ["auth", "createUser"] },
            "description": "Register a new user. Multipart form; `image` is optional. `name`, `email`, `password` are required."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Auto-save JWT into the {{token}} collection variable",
                  "try {",
                  "  const res = pm.response.json();",
                  "  const t = res.token || res.accessToken || (res.data && res.data.token);",
                  "  if (t) { pm.collectionVariables.set('token', t); console.log('Saved token'); }",
                  "} catch (e) { console.log('No JSON token in response'); }"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": { "raw": "{{API}}/auth/loginController", "host": ["{{API}}"], "path": ["auth", "loginController"] },
            "description": "Login with email + password. Returns a JWT; the test script auto-stores it in `{{token}}`."
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{API}}/auth/logoutController", "host": ["{{API}}"], "path": ["auth", "logoutController"] },
            "description": "Logout the current session."
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{API}}/auth/GetUserById/:id",
              "host": ["{{API}}"],
              "path": ["auth", "GetUserById", ":id"],
              "variable": [{ "key": "id", "value": "", "description": "User UUID" }]
            },
            "description": "Fetch a single user by UUID. Requires Bearer token."
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{API}}/auth/GetAllUsers?page=1&limit=10&name=",
              "host": ["{{API}}"],
              "path": ["auth", "GetAllUsers"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "name", "value": "", "description": "Search by name" }
              ]
            },
            "description": "Paginated list of users. Supports `page`, `limit`, `name` filter."
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "John Updated", "type": "text" },
                { "key": "address", "value": "New Address", "type": "text" },
                { "key": "age", "value": "29", "type": "text" },
                { "key": "country", "value": "Pakistan", "type": "text" },
                { "key": "city", "value": "Lahore", "type": "text" },
                { "key": "image", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{API}}/auth/updateUser/:id",
              "host": ["{{API}}"],
              "path": ["auth", "updateUser", ":id"],
              "variable": [{ "key": "id", "value": "", "description": "User UUID" }]
            },
            "description": "Update an existing user. Multipart so an optional new `image` can be uploaded."
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{API}}/auth/DeleteUser/:id",
              "host": ["{{API}}"],
              "path": ["auth", "DeleteUser", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "description": "Delete one user by UUID."
          }
        },
        {
          "name": "Bulk Delete Users",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ids\": [\"<uuid-1>\", \"<uuid-2>\"]\n}"
            },
            "url": { "raw": "{{API}}/auth/BulkDeleteUser", "host": ["{{API}}"], "path": ["auth", "BulkDeleteUser"] },
            "description": "Delete multiple users in one call. Body: `{ \"ids\": [..] }`."
          }
        }
      ]
    },
